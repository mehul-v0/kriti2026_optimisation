{
  "_comment": "VRP Solver Configuration. Edit values and re-run (no recompilation needed).",

  "penalty_weights": {
    "_comment_1": "These control the ALNS internal priority hierarchy.",
    "_comment_2": "The solver minimizes: unassigned > time_violations > lateness > pref_violations > dollar_cost.",
    "_comment_3": "For P1 employees, lateness reduction should dominate preference violations.",
    "unassigned_employee_penalty": 100000.0,
    "time_violation_penalty": 100000.0,
    "lateness_per_minute_penalty": 5.0,
    "priority_lateness_multiplier": 2.0,
    "preference_violation_penalty": 2000.0,
    "vehicle_activation_cost": 20.0,
    "wait_with_pax_penalty": 0.3,
    "priority_ride_time_weight": 0.5
  },

  "objective_weights": {
    "_comment": "Final output score = cost_weight * dollar_cost + time_weight * travel_time_minutes. These are overridden by test case input JSON if present.",
    "cost_weight": 0.7,
    "time_weight": 0.3
  },

  "priority_lateness_weights": {
    "_comment": "Multiplier on each priority level's lateness minutes. Higher = stricter.",
    "P1": 10.0,
    "P2": 5.0,
    "P3": 3.0,
    "P4": 2.0,
    "P5": 1.0
  },

  "local_search_weights": {
    "_comment": "Weights used in weighted_violation_score() for local search move decisions.",
    "hard_violation_weight": 10000000,
    "pref_violation_weight": 5000.0,
    "lateness_weight": 0
  },

  "sa_parameters": {
    "_comment": "Simulated Annealing / ALNS tuning. Lower cooling = more exploration but slower convergence.",
    "start_temperature": 50000.0,
    "cooling_rate": 0.99995,
    "min_destroy_percent": 0.10,
    "max_destroy_percent": 0.60,
    "reheat_threshold_iters": 800,
    "max_reheats": 20,
    "reheat_factor": 0.4,
    "adaptive_temp_scale": 0.5
  },

  "alns_operator_weights": {
    "_comment": "ALNS adaptive weight management and reward scores.",
    "sigma1_new_best": 33.0,
    "sigma2_improve_current": 9.0,
    "sigma3_accepted_worse": 3.0,
    "decay_factor": 0.8,
    "weight_update_scale": 10.0,
    "min_operator_weight": 0.1,
    "weight_update_interval": 500,
    "initial_destroy_weights": {
      "random_removal": 1.0,
      "worst_removal": 1.0,
      "shaw_removal": 1.0,
      "route_removal": 1.0,
      "violation_removal": 1.0,
      "consolidation_removal": 2.0,
      "cross_vehicle_removal": 1.5,
      "vehicle_elimination": 2.5,
      "expensive_arc_removal": 2.0,
      "string_removal": 1.5,
      "lateness_targeted_removal": 3.0,
      "ejection_chain_removal": 2.0
    },
    "initial_repair_weights": {
      "greedy_insertion": 1.0,
      "regret_insertion": 4.0,
      "nearest_insertion": 1.0,
      "batching_insertion": 2.0,
      "cheapest_vehicle_insertion": 4.0
    }
  },

  "shaw_removal": {
    "_comment": "Relatedness coefficients for Shaw removal operator.",
    "time_similarity_coeff": 0.01,
    "cost_similarity_coeff": 0.005
  },

  "gls_parameters": {
    "_comment": "Guided Local Search parameters for escaping local optima.",
    "lambda_coefficient": 0.1,
    "update_interval": 200,
    "penalty_decay_on_reheat": 0.5,
    "edge_penalty_increment": 1.0
  },

  "adaptive_destroy": {
    "_comment": "Adaptive destroy sizing based on stagnation.",
    "stagnation_threshold_iters": 500,
    "stagnation_min_destroy": 0.30,
    "stagnation_max_destroy": 0.65,
    "improving_threshold_iters": 50,
    "improving_min_destroy": 0.08,
    "improving_max_destroy": 0.35,
    "restart_destroy_fraction": 0.333,
    "perturbation_swaps_min": 2,
    "perturbation_swaps_range": 2,
    "route_removal_max_routes": 2,
    "consolidation_removal_max_vehicles": 2
  },

  "vehicle_elimination": {
    "_comment": "Vehicle elimination destroy operator parameters.",
    "random_pick_probability": 0.3
  },

  "string_removal": {
    "_comment": "String removal operator parameters.",
    "cross_vehicle_discount": 0.5
  },

  "local_search_passes": {
    "_comment": "Maximum iteration passes for local search phases.",
    "intra_route_max_passes": 3,
    "inter_route_max_passes": 3,
    "cross_exchange_max_passes": 2,
    "cross_exchange_frequency": 5,
    "post_alns_max_passes": 150,
    "final_reopt_max_passes": 50,
    "or_opt_max_segment_length": 3,
    "exact_tsp_max_route_size": 6,
    "violation_to_cost_factor": 1000.0,
    "consolidation_max_route_size": 4,
    "consolidation_max_orderings": 10
  },

  "repair_parameters": {
    "_comment": "Parameters for repair operators.",
    "new_trip_penalty": 15.0,
    "time_penalty_multiplier": 0.1,
    "regret_k": 3
  },

  "construction": {
    "_comment": "How many top initial solutions get ALNS time, and how the time is split.",
    "num_candidates_to_optimize": 3,
    "time_split_percent": [50, 30, 20],
    "trip_time_estimate_minutes": 30,
    "min_trips_per_vehicle": 4,
    "trips_buffer": 2,
    "infeasible_pref_penalty": 50000.0,
    "infeasible_trip_idx_weight": 10000.0,
    "infeasible_earlier_trip_bonus": 5000.0,
    "infeasible_lateness_coeff": 10.0
  },

  "constraints": {
    "_comment": "Constraint propagation parameters.",
    "min_trip_time_minutes": 30
  },

  "consolidation": {
    "detour_ratio_threshold": 1.5,
    "detour_penalty_multiplier": 10.0
  },

  "neighbor_list": {
    "_comment": "Number of nearest neighbors to track per employee.",
    "K": 10
  },

  "solution_pool": {
    "_comment": "Multi-start diversification parameters.",
    "max_pool_size": 5,
    "lahc_history_length": 500
  },

  "solver": {
    "default_time_limit_seconds": 30,
    "verbose": true
  }
}

##############
# Compiled binaries
##############
*.exe
*.out
*.o
*.obj
*.dll
*.so

##############
# Build directories
##############
build/
bin/
dist/

##############
# Python cache / env
##############
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
env/

##############
# Node (if used)
##############
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

##############
# Logs
##############
*.log

##############
# Output folder (keep structure, ignore contents)
##############
output/*
!output/.gitkeep

##############
# OS / Editor junk
##############
.DS_Store
.idea/
.vscode/

##############
# Secrets
##############
.env
.env.*
